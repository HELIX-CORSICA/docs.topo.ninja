    "languages": [
      {
        "language": "fr",
        "default": true,
        "tabs": [
          {
            "tab": "Guide",
            "groups": [
              {
                "group": "Pour commencer",
                "icon": "rocket",
                "pages": [
                  "fr/introduction",
                  "fr/premiers-pas"
                ]
              },
              {
                "group": "Outils",
                "icon": "toolbox",
                "pages": [
                  "fr/outils/fiche-controle",
                  "fr/outils/fiche-axe",
                  "fr/outils/fiche-signaletique",
                  "fr/outils/convertisseur-coordonnees",
                  "fr/outils/resection-3d"
                ]
              },
              {
                "group": "Fonctionnalites",
                "icon": "puzzle-piece",
                "pages": [
                  "fr/fonctionnalites/editeur-masse",
                  "fr/fonctionnalites/import-export-csv",
                  "fr/fonctionnalites/assignateur-roles",
                  "fr/fonctionnalites/appairage-automatique",
                  "fr/fonctionnalites/photos-points"
                ]
              },
              {
                "group": "Formules et calculs",
                "icon": "square-root-variable",
                "pages": [
                  "fr/formules/distances-orthogonales",
                  "fr/formules/gdop-qualite",
                  "fr/formules/visibilite-3d",
                  "fr/formules/transformations-coordonnees"
                ]
              },
              {
                "group": "Abonnements",
                "icon": "credit-card",
                "pages": [
                  "fr/abonnements"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Guide",
            "groups": [
              {
                "group": "Getting started",
                "icon": "rocket",
                "pages": [
                  "en/introduction",
                  "en/getting-started"
                ]
              },
              {
                "group": "Tools",
                "icon": "toolbox",
                "pages": [
                  "en/tools/control-sheet",
                  "en/tools/axis-control-sheet",
                  "en/tools/signaletic-sheet",
                  "en/tools/coordinate-converter",
                  "en/tools/3d-resection"
                ]
              },
              {
                "group": "Features",
                "icon": "puzzle-piece",
                "pages": [
                  "en/features/bulk-editor",
                  "en/features/csv-import-export",
                  "en/features/role-assignment",
                  "en/features/auto-pairing",
                  "en/features/point-photos"
                ]
              },
              {
                "group": "Formulas and calculations",
                "icon": "square-root-variable",
                "pages": [
                  "en/formulas/orthogonal-distances",
                  "en/formulas/gdop-quality",
                  "en/formulas/3d-visibility",
                  "en/formulas/coordinate-transformations"
                ]
              },
              {
                "group": "Subscriptions",
                "icon": "credit-card",
                "pages": [
                  "en/subscriptions"
                ]
              }
            ]
          }
        ]
      }
