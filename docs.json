{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "Topo.ninja Docs",
  "colors": {
    "primary": "#289e22",
    "light": "#4ade80",
    "dark": "#078b00"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://topo.ninja"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@topo.ninja"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Ouvrir Topo.ninja",
      "href": "https://topo.ninja"
    }
  },
